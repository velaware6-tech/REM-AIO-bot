TOKEN=
BOT_NAME=REM ALL IN ONE BOT
OWNER_IDS=
BYPASS_IDS=
COMMAND_LOG_IGNORE_IDS=
SUPPORT_SERVER=https://discord.com/invite/codexdev
SUPPORT_CHANNEL=
COMMAND_LOG_WEBHOOK_URL=
LOG_LEVEL=INFO
ENABLE_KEEP_ALIVE=true
PORT=8080

# Optional guild join/leave log channels (leave empty to disable)
GUILD_JOIN_LOG_CHANNEL_ID=
GUILD_LEAVE_LOG_CHANNEL_ID=

# Optional AI/chat config used by utils/ai_utils.py.
LANGUAGE=en
INTERNET_ACCESS=false
API_BASE_URL=https://api.openai.com/v1
MODEL_ID=gpt-4o-mini
OPENAI_API_KEY=

# Optional third-party API keys (commands degrade gracefully if unset)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
GIPHY_TOKEN=
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
RAPIDAPI_KEY=
RAPIDAPI_HOST=truth-dare.p.rapidapi.com
OPENWEATHER_API_KEY=
PEXELS_API_KEY=

EMOJI_SYNC_STARTUP_AUTO_SYNC=true

# Lavalink/Wavelink music node. Recommended: run your own Lavalink server.
LAVALINK_ENABLED=true
LAVALINK_IDENTIFIER=main
LAVALINK_URI=
LAVALINK_PORT=2333
LAVALINK_SECURE=false
LAVALINK_PASSWORD=
LAVALINK_HEARTBEAT=15
LAVALINK_RETRIES=3
LAVALINK_PRECHECK=true
LAVALINK_PRECHECK_TIMEOUT=8
# Optional advanced format:
# LAVALINK_NODES_JSON=[{"identifier":"main","uri":"http://127.0.0.1:2333","password":"youshallnotpass"}]
LAVALINK_NODES_JSON=

# Optional: comma-separated Discord server IDs to copy custom emojis from.
# Example: EMOJI_SYNC_SOURCE_GUILD_IDS=123456789012345678,987654321098765432
EMOJI_SYNC_SOURCE_GUILD_IDS=
EMOJI_SYNC_CODE_EMOJIS=true

# Optional: comma-separated local folders containing emoji image files.
# Defaults are configured in config.yml: data/emojis, assets/emojis
EMOJI_SYNC_ASSET_DIRS=

# Top.gg vote webhook server (top-gg/ subproject)
TOPGG_WEBHOOK_AUTH=
TOPGG_VOTE_WEBHOOK_URL=
TOPGG_BOT_ID=1144179659735572640